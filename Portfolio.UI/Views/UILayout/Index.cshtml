@model Portfolio.Helper.Dtos.ContactDto
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en" class="dark">

@await Component.InvokeAsync("_UILayoutHeadComponentPartial")

<body class="bg-background-light dark:bg-background-dark text-slate-900 dark:text-slate-100 font-display">
    <div class="relative flex min-h-screen flex-col overflow-x-hidden w-full">

        @await Component.InvokeAsync("_UILayoutHeaderComponentPartial")

        <main class="flex-1 w-full flex flex-col items-center">

            <!-- Hero Section -->
            @await Component.InvokeAsync("_UILayoutHeroComponentPartial")
           <!-- /Hero Section -->

            <!-- About Section -->
            @await Component.InvokeAsync("_UILayoutAboutComponentPartial")
            <!-- /About Section -->

            <!-- Resume Section -->
            @await Component.InvokeAsync("_UILayoutResumeComponentPartial")
            <!-- /Resume Section -->

            <!-- Portfolio Section -->
            @await Component.InvokeAsync("_UILayoutPortfolioComponentPartial")
            <!-- /Portfolio Section -->

            <!-- Contact Section -->
            <section id="contact" class="flex flex-col max-w-7xl w-full mx-auto px-6 py-12 md:py-20 border-t border-slate-200 dark:border-slate-800 pt-16 mt-12">
                <div class="grid lg:grid-cols-2 gap-16">
                    <!-- Left Column: Content & Info -->
                    <div class="flex flex-col gap-10">
                        <div class="flex flex-col gap-4">
                            <span class="text-primary font-bold tracking-widest uppercase text-xs">Available for work</span>
                            <h2 class="text-5xl md:text-6xl font-black leading-tight tracking-tighter">Get in Touch</h2>
                            <p class="text-slate-600 dark:text-slate-400 text-lg max-w-md">
                                Have a project in mind or just want to say hi? I'd love to hear from you. Let's create something great together.
                            </p>
                        </div>
                        <div class="flex flex-col gap-8">
                            <!-- Contact Details -->
                            <div class="flex items-start gap-4">
                                <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-primary">
                                    <span class="material-symbols-outlined">mail</span>
                                </div>
                                <div>
                                    <p class="text-sm font-bold text-slate-500 uppercase tracking-wider">Email Address</p>
                                    <a class="text-xl font-semibold hover:text-primary transition-colors" href="mailto:alozdemir23@gmail.com">alozdemir23@gmail.com</a>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Right Column: Form -->
                    <div class="bg-slate-100 dark:bg-slate-800/50 p-8 md:p-12 rounded-3xl border border-slate-200 dark:border-slate-800">
                        <form action="/UILayout/Message" method="post" class="flex flex-col gap-6">
                            <div class="flex flex-col gap-2">
                                <label class="text-sm font-bold text-slate-700 dark:text-slate-300">Name</label>
                                <input asp-for="NameSurname" class="w-full rounded-xl border-slate-200 dark:border-slate-700 bg-white dark:bg-background-dark p-4 text-slate-900 dark:text-slate-100 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" placeholder="Your Name" />
                            </div>
                            <div class="flex flex-col gap-2">
                                <label class="text-sm font-bold text-slate-700 dark:text-slate-300">Email Address</label>
                                <input asp-for="Email" type="email" class="w-full rounded-xl border-slate-200 dark:border-slate-700 bg-white dark:bg-background-dark p-4 text-slate-900 dark:text-slate-100 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" placeholder="your.email@example.com" />
                            </div>
                            <div class="flex flex-col gap-2">
                                <label class="text-sm font-bold text-slate-700 dark:text-slate-300">Subject</label>
                                <input asp-for="Subject" class="w-full rounded-xl border-slate-200 dark:border-slate-700 bg-white dark:bg-background-dark p-4 text-slate-900 dark:text-slate-100 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" placeholder="Subject" />
                            </div>
                            <div class="flex flex-col gap-2">
                                <label class="text-sm font-bold text-slate-700 dark:text-slate-300">Message</label>
                                <textarea asp-for="Mesaage" class="w-full rounded-xl border-slate-200 dark:border-slate-700 bg-white dark:bg-background-dark p-4 text-slate-900 dark:text-slate-100 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all resize-none" placeholder="Tell me about your project or idea..." rows="5"></textarea>
                            </div>
                            <button type="submit" class="mt-4 flex w-full items-center justify-center gap-2 rounded-xl bg-primary py-4 text-white font-bold text-lg hover:opacity-95 transition-all active:scale-[0.98]">
                                Send Message
                                <span class="material-symbols-outlined text-xl">send</span>
                            </button>
                        </form>
                    </div>
                </div>
            </section>
            <!-- /Contact Section -->

        </main>
        
        @await Component.InvokeAsync("_UILayoutFooterComponentPartial")

        @await Component.InvokeAsync("_UILayoutScriptComponentPartial")
    </div>
</body>

</html>
