@model Portfolio.UI.CustomeModel.Resume

<section id="resume" class="flex flex-col max-w-7xl w-full mx-auto px-6 py-12 md:py-20 border-t border-slate-200 dark:border-slate-800 pt-16 mt-12">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-12">
        <h2 class="text-slate-900 dark:text-white text-4xl md:text-5xl font-black leading-tight tracking-tight">Resume</h2>
        <a href="~/CV/AlperÖZDEMİR.pdf" target="_blank" class="flex items-center justify-center gap-2 rounded-xl bg-primary px-6 py-3 text-white font-bold text-sm hover:opacity-90 transition-all active:scale-95 whitespace-nowrap">
            <span class="material-symbols-outlined text-lg">download</span>
            View CV
        </a>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <!-- Education Column -->
        <div>
            <div class="flex items-center gap-4 mb-12">
                <span class="material-symbols-outlined text-primary text-3xl">school</span>
                <h3 class="text-3xl font-bold">Education</h3>
                <div class="h-px flex-1 bg-slate-200 dark:bg-slate-800"></div>
            </div>
            
            <div class="space-y-12">
                @foreach (var item in Model.Educations)
                {
                    <div class="relative pl-8 border-l-2 border-primary/30">
                        <div class="absolute -left-[9px] top-0 w-4 h-4 rounded-full bg-slate-300 dark:bg-slate-700 border-4 border-background-light dark:border-background-dark"></div>
                        <div class="flex flex-col lg:flex-row lg:justify-between mb-2">
                            <h3 class="text-xl font-bold text-slate-900 dark:text-white">@item.Degree</h3>
                            <span class="text-primary font-semibold text-sm">@item.Year</span>
                        </div>
                        <p class="text-lg font-medium text-slate-600 dark:text-slate-400 mb-3">@item.University</p>
                        <p class="text-slate-700 dark:text-slate-300 leading-relaxed">@item.Description</p>
                    </div>
                }
            </div>
        </div>

        <!-- Experience Column -->
        <div>
            <div class="flex items-center gap-4 mb-12">
                <span class="material-symbols-outlined text-primary text-3xl">work</span>
                <h3 class="text-3xl font-bold">Experience</h3>
                <div class="h-px flex-1 bg-slate-200 dark:bg-slate-800"></div>
            </div>
            
            <div class="space-y-12">
                @foreach (var item in Model.Experiences)
                {
                    <div class="relative pl-8 border-l-2 border-primary/30">
                        <div class="absolute -left-[9px] top-0 w-4 h-4 rounded-full bg-primary border-4 border-background-light dark:border-background-dark"></div>
                        <div class="flex flex-col lg:flex-row lg:justify-between mb-2">
                            <h3 class="text-xl font-bold text-slate-900 dark:text-white">@item.Title</h3>
                            <span class="text-primary font-semibold text-sm">@item.Duration</span>
                        </div>
                        <p class="text-lg font-medium text-slate-600 dark:text-slate-400 mb-3">@item.Company</p>
                        <p class="text-slate-700 dark:text-slate-300 leading-relaxed">@item.Responsibilities</p>
                    </div>
                }
            </div>
        </div>
    </div>
</section>