@model List<Portfolio.Helper.Dtos.ProjectDto>

<section id="portfolio" class="flex flex-col max-w-7xl w-full mx-auto px-6 py-12 md:py-20 border-t border-slate-200 dark:border-slate-800 pt-16 mt-12">
    <div class="flex flex-col gap-4 mb-12">
        <h2 class="text-slate-900 dark:text-white text-4xl md:text-5xl font-black leading-tight tracking-tight">Portfolio</h2>
        <p class="text-slate-500 dark:text-slate-400 text-lg max-w-2xl leading-relaxed">
            A curated selection of my latest projects.
        </p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">
        @foreach (var item in Model)
        {
            <div class="group flex flex-col gap-5 bg-white dark:bg-slate-800/50 rounded-2xl p-4 border border-slate-200 dark:border-slate-700 hover:border-primary/50 transition-colors">
                <div class="relative w-full aspect-[16/10] bg-slate-200 dark:bg-slate-800 rounded-xl overflow-hidden shadow-sm transition-all group-hover:shadow-xl group-hover:-translate-y-1">
                    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('@item.Image')"></div>
                    <div class="absolute inset-0 bg-gradient-to-t from-slate-900/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-6">
                        <a href="/UIProjectReview/Index/@item.ID" class="text-white font-medium flex items-center gap-2">View Details <span class="material-symbols-outlined text-sm">arrow_forward</span></a>
                    </div>
                </div>
                <div class="flex flex-col gap-2 pt-2 px-2">
                    <div class="flex items-center justify-between">
                        <h3 class="text-slate-900 dark:text-white text-xl font-bold group-hover:text-primary transition-colors">@item.Header</h3>
                    </div>
                    <p class="text-slate-500 dark:text-slate-400 text-base leading-relaxed line-clamp-2">
                        @item.Description
                    </p>
                    <a class="mt-4 inline-flex items-center text-primary font-bold text-sm gap-1 hover:gap-2 transition-all" href="/UIProjectReview/Index/@item.ID">
                        View Project <span class="material-symbols-outlined text-lg">chevron_right</span>
                    </a>
                </div>
            </div>
        }
    </div>
</section>