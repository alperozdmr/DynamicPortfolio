# Neon Database Configuration
NEON_API_KEY=your_neon_api_key_here
NEON_PROJECT_ID=your_neon_project_id_here
BRANCH_ID=your_branch_id_here

# Portfolio UI Database Configuration
DB_CONNECTION_STRING=Host=your-neon-endpoint;Database=neondb;Username=user;Password=pass;SSL Mode=VerifyFull;

# Admin Seed Configuration
SEED_ENABLED=true
SEED_ADMIN_ROLE=Admin
SEED_ADMIN_EMAIL=admin@yourdomain.com
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=Password123!
SEED_ADMIN_NAME=Admin
SEED_ADMIN_SURNAME=User
